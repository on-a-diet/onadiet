# Supply-chain cooldown: ignore npm releases newer than 3 days. NOTE: pnpm honors minimumReleaseAge only on
# pnpm >=10.16 — this repo pins pnpm 9.15 (packageManager), where it's currently a no-op. The enforced
# cooldown today is Dependabot's `cooldown:` in .github/dependabot.yml (the real dependency-update path).
minimumReleaseAge=4320
# fail loudly rather than silently hoisting
shamefully-hoist=false
# reproducible CI installs
prefer-frozen-lockfile=true
