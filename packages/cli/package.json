{
  "name": "onadiet",
  "version": "0.1.1",
  "type": "module",
  "sideEffects": false,
  "description": "Put your files on a diet — the `diet` CLI. Shrink PDFs, images, and folders under a size limit, locally, no upload, safe by default.",
  "keywords": [
    "compress",
    "compression",
    "optimize",
    "shrink",
    "target-size",
    "compress-pdf",
    "optimize-pdf",
    "compress-image",
    "compress-folder",
    "local",
    "no-upload",
    "cli",
    "diet",
    "onadiet"
  ],
  "license": "Apache-2.0",
  "author": "Sharvil Kadam",
  "engines": {
    "node": ">=22"
  },
  "homepage": "https://onadiet.pages.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/on-a-diet/onadiet.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/on-a-diet/onadiet/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "diet": "bin/diet.js",
    "onadiet": "bin/diet.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:perf": "vitest run --config vitest.perf.config.ts"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "sharp": "^0.34.4",
    "svgo": "^4.0.2"
  },
  "devDependencies": {
    "@onadiet/core": "workspace:*",
    "@onadiet/pdf": "workspace:*",
    "@onadiet/image": "workspace:*",
    "@onadiet/svg": "workspace:*",
    "@onadiet/testkit": "workspace:*",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
