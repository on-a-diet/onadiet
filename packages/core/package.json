{
  "name": "@onadiet/core",
  "version": "0.1.1",
  "type": "module",
  "sideEffects": false,
  "description": "onadiet core: the pure engine — detect · weigh · plan · slim · verify · report, the FormatAdapter / QualityMetric / SizeSearch seams, diet plans, size parsing. No I/O.",
  "keywords": [
    "compress",
    "compression",
    "optimize",
    "shrink",
    "target-size",
    "ssim",
    "quality-floor",
    "size-search",
    "local",
    "no-upload",
    "onadiet"
  ],
  "license": "Apache-2.0",
  "author": "Sharvil Kadam",
  "engines": {
    "node": ">=22"
  },
  "homepage": "https://github.com/on-a-diet/onadiet/tree/main/packages/core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/on-a-diet/onadiet.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/on-a-diet/onadiet/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
